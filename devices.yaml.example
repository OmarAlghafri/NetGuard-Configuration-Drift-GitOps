# NetGuard device inventory — EXAMPLE
# Copy to devices.yaml and fill in real credentials.
# devices.yaml is gitignored; never commit real passwords.

defaults:
  device_type: cisco_ios      # Netmiko driver for Cisco IOS (c3725 / dynamips)
  username: admin             # priv-15 user configured on each device
  password: "REPLACE_ME"      # admin password
  # secret: "REPLACE_ME"      # enable secret (only if not already priv 15)
  port: 22                    # SSH

# Management network = 10.99.99.0/24 (GNS3 loopback adapter, 10.99.99.1)
devices:
  - name: R1
    host: 10.99.99.20
    role: router
  - name: R2
    host: 10.99.99.21
    role: router
  - name: SW1
    host: 10.99.99.22
    role: switch
